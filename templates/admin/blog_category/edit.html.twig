{% extends '_layouts/admin.html.twig' %}

{% block title %}Edit Category - Admin Panel{% endblock %}
{% block page_title %}Edit Category: {{ category.title }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white border-4 border-black p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
        <div class="flex items-center gap-4 mb-8 border-b-4 border-black pb-4">
            <span class="text-4xl">🖋️</span>
            <h2 class="text-3xl font-black uppercase">Update Category</h2>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_row(form.title) }}
            {{ form_row(form.slug) }}
            
            <div class="flex gap-4 mt-8">
                <button type="submit" class="flex-grow bg-indigo-400 text-black border-4 border-black font-black uppercase text-xl py-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
                    Update Category
                </button>
                <a href="{{ path('admin_category_index') }}" class="flex-grow bg-white text-black border-4 border-black font-black uppercase text-xl py-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all text-center">
                    Cancel
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

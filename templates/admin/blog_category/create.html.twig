{% extends '_layouts/admin.html.twig' %}

{% block title %}New Category - Admin Panel{% endblock %}
{% block page_title %}New Category{% endblock %}

{% block body %}
{# Top Actions Bar #}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10 pb-6 border-b-4 border-black">
    <div>
        <h2 class="text-4xl font-black uppercase tracking-tight">Add Category</h2>
        <p class="font-bold text-gray-500 uppercase text-sm italic">Organize your blog posts into logical groups</p>
    </div>
    <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
        <a href="{{ path('admin_category_index') }}" class="flex-1 md:flex-none text-center bg-white border-4 border-black font-black uppercase px-6 py-3 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all text-sm">
            ❌ Cancel
        </a>
        <button type="submit" form="create-category-form" class="flex-[2] md:flex-none bg-lime-400 border-4 border-black font-black uppercase px-10 py-3 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all text-sm">
            🚀 Create Category
        </button>
    </div>
</div>

<div class="max-w-3xl">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'create-category-form'}}) }}
        <div class="bg-white border-4 border-black p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
            <div class="space-y-6">
                {{ form_row(form.title) }}
                {{ form_row(form.slug) }}
            </div>
        </div>
    {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const titleInput = document.querySelector('input[name="blog_category[title]"]');
    const slugInput = document.querySelector('input[name="blog_category[slug]"]');
    
    if (titleInput && slugInput) {
        titleInput.addEventListener('input', function() {
            slugInput.value = titleInput.value
                .toLowerCase()
                .replace(/[^\w\s-]/g, '')
                .replace(/[\s_-]+/g, '-')
                .replace(/^-+|-+$/g, '');
        });
    }
});
</script>
{% endblock %}

{% extends '_layouts/admin.html.twig' %}

{% block title %}Categories - Admin Panel{% endblock %}
{% block page_title %}Manage Categories{% endblock %}

{% block body %}
<div class="mb-10 flex justify-between items-center flex-wrap gap-4">
    <h2 class="text-3xl font-black uppercase tracking-tight">Active Categories</h2>
    <a href="{{ path('admin_category_new') }}" class="bg-yellow-300 border-4 border-black font-black uppercase px-8 py-3 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        + Add New Category
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="bg-green-300 border-4 border-black p-4 mb-8 font-bold shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        {{ message }}
    </div>
{% endfor %}

<div class="bg-white border-4 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
        <thead class="bg-indigo-300 border-b-4 border-black font-black uppercase">
            <tr>
                <th class="p-6">ID</th>
                <th class="p-6">Title</th>
                <th class="p-6">Slug</th>
                <th class="p-6 text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y-4 divide-black font-bold">
            {% for category in categories %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-6">#{{ category.id }}</td>
                    <td class="p-6">
                        <span class="bg-pink-300 border-2 border-black px-3 py-1 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">{{ category.title }}</span>
                    </td>
                    <td class="p-6 text-gray-600">{{ category.slug }}</td>
                    <td class="p-6 text-right space-x-2">
                        <a href="{{ path('admin_category_edit', {'id': category.id}) }}" class="bg-white border-2 border-black px-4 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all uppercase text-sm font-black inline-block">Edit</a>
                        
                        <form method="post" action="{{ path('admin_category_delete', {'id': category.id}) }}" class="inline-block" onsubmit="return confirm('Are you sure you want to delete this category?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                            <button class="bg-[#ff5c5c] border-2 border-black px-4 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all uppercase text-sm font-black cursor-pointer">
                                Del
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="p-12 text-center text-gray-500 italic">No categories found. Start by adding one!</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>
{% endblock %}

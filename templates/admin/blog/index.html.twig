{% extends '_layouts/admin.html.twig' %}

{% block title %}Blog Posts - Admin Panel{% endblock %}
{% block page_title %}Manage Blog Posts{% endblock %}

{% block body %}
<div class="mb-10 flex justify-between items-center flex-wrap gap-4">
    <h2 class="text-3xl font-black uppercase tracking-tight">Post Inventory</h2>
    <a href="{{ path('admin_blog_new') }}" class="bg-lime-400 border-4 border-black font-black uppercase px-8 py-3 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all text-xl">
        + Create New Post
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="bg-green-300 border-4 border-black p-4 mb-8 font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        {{ message }}
    </div>
{% endfor %}

<div class="bg-white border-4 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-indigo-300 border-b-4 border-black font-black uppercase text-sm">
                <tr>
                    <th class="p-6">Thumbnail</th>
                    <th class="p-6">Content Details</th>
                    <th class="p-6">Category</th>
                    <th class="p-6">Status</th>
                    <th class="p-6 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y-4 divide-black font-bold">
                {% for blog in blogs %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-6 w-32">
                            {% if blog.thumbnail %}
                                <img src="{{ asset('uploads/thumbnails/' ~ blog.thumbnail) }}" alt="{{ blog.title }}" class="w-20 h-20 object-cover border-4 border-black shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                            {% else %}
                                <div class="w-20 h-20 bg-gray-200 border-4 border-black shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center text-3xl">
                                    🖼️
                                </div>
                            {% endif %}
                        </td>
                        <td class="p-6">
                            <div class="flex flex-col gap-1">
                                <span class="text-xl font-black uppercase leading-tight">{{ blog.title }}</span>
                                <span class="text-xs text-gray-500 font-mono">/{{ blog.slug }}</span>
                                <div class="mt-2 text-xs flex gap-2">
                                    <span class="bg-gray-200 px-2 py-0.5 border-2 border-black">By {{ blog.author.name }}</span>
                                    <span class="bg-gray-200 px-2 py-0.5 border-2 border-black">{{ blog.createdAt|date('M d, Y') }}</span>
                                </div>
                            </div>
                        </td>
                        <td class="p-6">
                            <span class="bg-pink-300 border-2 border-black px-3 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] uppercase text-xs font-black">
                                {{ blog.category.title }}
                            </span>
                        </td>
                        <td class="p-6">
                            {% set statusColor = 'bg-gray-300' %}
                            {% if blog.status == 'published' %}
                                {% set statusColor = 'bg-lime-400' %}
                            {% elseif blog.status == 'draft' %}
                                {% set statusColor = 'bg-yellow-300' %}
                            {% endif %}
                            
                            <div class="inline-flex items-center gap-2">
                                <span class="{{ statusColor }} border-2 border-black px-3 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] uppercase text-xs font-black">
                                    {{ blog.status }}
                                </span>
                                {% if not blog.isEnable %}
                                    <span class="bg-red-500 text-white border-2 border-black px-2 py-0.5 text-[10px] font-black uppercase">Disabled</span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="p-6 text-right">
                            <div class="flex justify-end gap-3 items-center">
                                <a href="{{ path('admin_blog_edit', {'id': blog.id}) }}" class="bg-white border-2 border-black px-4 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all uppercase text-sm font-black">
                                    Edit
                                </a>
                                
                                <form method="post" action="{{ path('admin_blog_delete', {'id': blog.id}) }}" class="inline-block" onsubmit="return confirm('Are you sure you want to delete this post?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ blog.id) }}">
                                    <button class="bg-[#ff5c5c] border-2 border-black px-4 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all uppercase text-sm font-black cursor-pointer">
                                        Del
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="p-20 text-center">
                            <div class="flex flex-col items-center gap-4">
                                <span class="text-6xl">📭</span>
                                <p class="text-2xl font-black uppercase">No blog posts found.</p>
                                <a href="{{ path('admin_blog_new') }}" class="text-indigo-600 underline font-black uppercase">Click here to create your first post!</a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

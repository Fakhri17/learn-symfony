{% extends '_layouts/base.html.twig' %}

{% block title %}Admin Login - Neobrutalism{% endblock %}

{% block body %}
<div class="max-w-md mx-auto mt-12 mb-20">
    <div class="bg-white border-4 border-black p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] relative">
        <h1 class="text-4xl font-black uppercase mb-8 border-b-4 border-black pb-4">Admin Login</h1>

        {% if error %}
            <div class="bg-red-300 border-4 border-black p-4 mb-6 font-bold shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="mb-6">
                <label for="email" class="block font-black uppercase mb-2 text-lg">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="email" class="w-full border-4 border-black p-3 font-bold text-lg focus:outline-none focus:ring-4 focus:ring-yellow-300 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] bg-white" autocomplete="email" required autofocus>
            </div>
            
            <div class="mb-8">
                <label for="password" class="block font-black uppercase mb-2 text-lg">Password</label>
                <input type="password" name="password" id="password" class="w-full border-4 border-black p-3 font-bold text-lg focus:outline-none focus:ring-4 focus:ring-yellow-300 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] bg-white" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full bg-lime-300 text-black border-4 border-black font-black uppercase text-xl py-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
                Sign In
            </button>
        </form>
    </div>
    
    <div class="mt-10 text-center">
        <a href="/" class="font-black uppercase border-b-2 border-black hover:bg-yellow-300 transition-colors">← Back to Blog</a>
    </div>
</div>
{% endblock %}

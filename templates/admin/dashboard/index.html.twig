{% extends '_layouts/base.html.twig' %}

{% block title %}Admin Dashboard - Neobrutalism{% endblock %}

{% block body %}
<div class="mb-10 flex justify-between items-center bg-yellow-300 border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
    <div>
        <h1 class="text-4xl font-black uppercase tracking-tight">Admin Dashboard</h1>
        <p class="font-bold">Welcome back, {{ app.user.name }}!</p>
    </div>
    <a href="{{ path('admin_logout') }}" class="bg-pink-400 border-4 border-black font-black uppercase px-6 py-2 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all">
        Logout
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
    <div class="bg-white border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-center">
        <p class="font-black uppercase text-gray-600 mb-2">Total Posts</p>
        <p class="text-6xl font-black">0</p>
    </div>
    <div class="bg-white border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-center">
        <p class="font-black uppercase text-gray-600 mb-2">Categories</p>
        <p class="text-6xl font-black">4</p>
    </div>
    <div class="bg-white border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-center">
        <p class="font-black uppercase text-gray-600 mb-2">Users</p>
        <p class="text-6xl font-black">1</p>
    </div>
</div>

<div class="bg-indigo-300 border-4 border-black p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
    <h2 class="text-3xl font-black uppercase mb-6">Quick Actions</h2>
    <div class="flex flex-wrap gap-4">
        <a href="#" class="bg-white border-4 border-black font-black uppercase px-8 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all">
            + New Blog Post
        </a>
        <a href="#" class="bg-white border-4 border-black font-black uppercase px-8 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all">
            Manage Categories
        </a>
        <a href="#" class="bg-white border-4 border-black font-black uppercase px-8 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all">
            User Settings
        </a>
    </div>
</div>
{% endblock %}

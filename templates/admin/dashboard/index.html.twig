{% extends '_layouts/admin.html.twig' %}

{% block title %}Dashboard - Admin Panel{% endblock %}
{% block page_title %}Dashboard Overview{% endblock %}

{% block body %}
<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
    <div class="bg-white border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all">
        <p class="font-black uppercase text-gray-500 mb-2 tracking-widest text-xs">Total Posts</p>
        <div class="flex items-end justify-between">
            <p class="text-6xl font-black">{{ total_blogs }}</p>
            <span class="text-3xl">📝</span>
        </div>
    </div>
    <div class="bg-white border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all">
        <p class="font-black uppercase text-gray-500 mb-2 tracking-widest text-xs">Categories</p>
        <div class="flex items-end justify-between">
            <p class="text-6xl font-black">{{ total_categories }}</p>
            <span class="text-3xl">📁</span>
        </div>
    </div>
    <div class="bg-white border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all">
        <p class="font-black uppercase text-gray-500 mb-2 tracking-widest text-xs">Total Users</p>
        <div class="flex items-end justify-between">
            <p class="text-6xl font-black">{{ total_users }}</p>
            <span class="text-3xl">👥</span>
        </div>
    </div>
</div>

{% endblock %}
